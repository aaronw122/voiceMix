# Copy to .env ON THE BOX and fill in real values. Never commit the real .env.
# CI ships this .env.example but leaves your existing .env untouched.

# --- Cloudflare Tunnel ---
# Token for the remotely-managed tunnel (Cloudflare dashboard ->
# Networks -> Tunnels -> your tunnel -> Install connector -> copy the
# token from the `--token ey...` value). Routes (api.voicemix.awill.co ->
# backend:8000) are configured in the dashboard, not here.
CF_TUNNEL_TOKEN=

# --- Image tag (CI overrides per deploy with the commit SHA; default for manual runs) ---
BACKEND_IMAGE_TAG=latest

# --- Backend app config (consumed by FastAPI) ---
# BASE_URL is REQUIRED and must be the public origin (the Cloudflare hostname):
# share/audio URLs in API responses embed it, and a mismatch produces dead links
# with no visible error. AUDIO_DIR/DB_PATH default to the clipdata volume paths
# baked into the image; override here only if the volume layout changes.
BASE_URL=https://voiceapi.awill.co
AUDIO_DIR=/data/audio
DB_PATH=/data/voicemix.db
ELEVENLABS_API_KEY=
# fine-tuned F5-TTS endpoints (ASR->TTS, target's full accent/cadence). One container per voice.
# unset -> that voice falls back to the passthrough stub. Fill the real .modal.run URLs in the
# box-local .env only (these are blank here on purpose — .env.example is a public template).
#   trump:    deploy: modal deploy pipeline/serve_f5_modal.py
#   dwarkesh: deploy: DWARKESH_APP_NAME=<secret> MODAL_PROFILE=youfoundaaron modal deploy pipeline/serve_f5_dwarkesh_modal.py
#   elon:     deploy: ELON_APP_NAME=<secret> MODAL_PROFILE=aaronmodal modal deploy pipeline/serve_f5_elon_modal.py
TTS_MODAL_ENDPOINT_URL=
DWARKESH_TTS_MODAL_ENDPOINT_URL=
ELON_TTS_MODAL_ENDPOINT_URL=https://aaronwillmodal--voicemix-tts-elon-ttsmodel-web.modal.run
