# Copy to .env ON THE BOX and fill in real values. Never commit the real .env.
# CI ships this .env.example but leaves your existing .env untouched.

# --- Domains (DNS A-records must point at the box) ---
API_DOMAIN=api.voicemix.example.com
STORAGE_DOMAIN=cdn.voicemix.example.com

# --- Postgres ---
POSTGRES_USER=voicemix
POSTGRES_PASSWORD=change-me
POSTGRES_DB=voicemix

# --- MinIO (S3-compatible object store) ---
MINIO_ROOT_USER=voicemix
MINIO_ROOT_PASSWORD=change-me-too

# --- Backend app config (consumed by FastAPI; german wires these up) ---
DATABASE_URL=postgresql://voicemix:change-me@postgres:5432/voicemix
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=https://cdn.voicemix.example.com
S3_ACCESS_KEY=voicemix
S3_SECRET_KEY=change-me-too
S3_BUCKET=clips
ELEVENLABS_API_KEY=
